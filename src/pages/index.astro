---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Why from "../components/Why.astro";
import Features from "../components/Features.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Install from "../components/Install.astro";
import OpenSource from "../components/OpenSource.astro";
import Footer from "../components/Footer.astro";

/**
 * Repo metrics fetched at build time so the rendered HTML ships with
 * current values (no client-side flash on load). A tiny script in Layout
 * also re-fetches client-side to keep them fresh between deploys.
 *
 * - STARS:     stargazers_count from /repos/...
 * - DOWNLOADS: sum of download_count across every asset of every release.
 *
 * Both fall back to last-known values if the GitHub API rate-limits the
 * Cloudflare build runner (unlikely; harmless if it does).
 */
const FALLBACK_STARS = 2;
const FALLBACK_DOWNLOADS = 0;
let STARS = FALLBACK_STARS;
let DOWNLOADS = FALLBACK_DOWNLOADS;
const HEADERS = {
  Accept: "application/vnd.github+json",
  "User-Agent": "snap2link-site-build",
};
try {
  const repoRes = await fetch(
    "https://api.github.com/repos/amys94fr/Snap2Link",
    { headers: HEADERS },
  );
  if (repoRes.ok) {
    const data = (await repoRes.json()) as { stargazers_count?: number };
    if (typeof data.stargazers_count === "number") STARS = data.stargazers_count;
  }
} catch {
  /* keep fallback */
}
try {
  const relRes = await fetch(
    "https://api.github.com/repos/amys94fr/Snap2Link/releases?per_page=100",
    { headers: HEADERS },
  );
  if (relRes.ok) {
    const releases = (await relRes.json()) as Array<{
      assets?: Array<{ download_count?: number }>;
    }>;
    DOWNLOADS = releases.reduce(
      (sum, r) =>
        sum +
        (r.assets ?? []).reduce((s, a) => s + (a.download_count ?? 0), 0),
      0,
    );
  }
} catch {
  /* keep fallback */
}
---

<Layout>
  <Nav stars={STARS} />
  <Hero />
  <Why />
  <Features />
  <HowItWorks />
  <Install />
  <OpenSource stars={STARS} downloads={DOWNLOADS} />
  <Footer />
</Layout>
