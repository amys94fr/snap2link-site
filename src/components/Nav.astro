---
interface Props {
  stars: number;
}
const { stars } = Astro.props;
---

<nav class="nav" data-screen-label="Nav">
  <a href="#top" class="nav-brand">
    <img
      src="/assets/logo-app-icon.png"
      width="28"
      height="28"
      alt=""
      style="border-radius: 6px;"
    />
    <span>Snap<b>2</b>Link</span>
  </a>
  <div class="nav-links">
    <a href="#features">Features</a>
    <a href="#how">How it works</a>
    <a href="#install">Download</a>
    <a href="#open">Open source</a>
  </div>
  <div class="nav-cta">
    <a
      href="https://github.com/sponsors/amys94fr"
      class="nav-sponsor"
      target="_blank"
      rel="noopener noreferrer"
      title="Sponsor Snap2Link on GitHub Sponsors"
      aria-label="Sponsor Snap2Link on GitHub Sponsors"
    >
      <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
        <path
          fill="currentColor"
          d="M4.25 2.5c-1.336 0-2.75 1.164-2.75 3 0 2.15 1.58 4.144 3.365 5.682A20.565 20.565 0 008 13.393a20.561 20.561 0 003.135-2.211C12.92 9.644 14.5 7.65 14.5 5.5c0-1.836-1.414-3-2.75-3-1.373 0-2.609.986-3.029 2.456a.75.75 0 01-1.442 0C6.859 3.486 5.623 2.5 4.25 2.5zM8 14.25l-.345.666-.002-.001-.006-.003-.018-.01a7.643 7.643 0 01-.31-.17 22.075 22.075 0 01-3.434-2.414C2.045 10.731 0 8.35 0 5.5 0 2.836 2.086 1 4.25 1 5.797 1 7.153 1.802 8 3.02 8.847 1.802 10.203 1 11.75 1 13.914 1 16 2.836 16 5.5c0 2.85-2.045 5.231-3.885 6.818a22.08 22.08 0 01-3.744 2.584l-.018.01-.006.003h-.002L8 14.25z"
        ></path>
      </svg>
      <span>Sponsor</span>
    </a>
    <a
      href="https://github.com/amys94fr/Snap2Link"
      class="gh-btn"
      target="_blank"
      rel="noopener noreferrer"
      title="View Snap2Link on GitHub"
      aria-label="View Snap2Link on GitHub"
    >
      <span class="gh-label">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.27-.01-.99-.02-1.95-3.2.69-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17.91-.25 1.89-.38 2.86-.39.97 0 1.95.13 2.86.39 2.18-1.48 3.14-1.17 3.14-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.07 0 4.4-2.69 5.37-5.26 5.65.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"
          ></path>
        </svg>
        GitHub
      </span>
      <span class="gh-stars">
        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" aria-hidden="true">
          <polygon
            points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
          ></polygon>
        </svg>
        <span data-gh-stars>{stars}</span>
      </span>
    </a>
    <a href="#install" class="btn primary sm">Get Snap2Link</a>
  </div>
</nav>
