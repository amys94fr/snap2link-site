---
const YEAR = new Date().getFullYear();
---

<footer class="footer" data-screen-label="Footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <a href="#top" class="nav-brand">
        <img
          src="/assets/logo-app-icon.png"
          width="24"
          height="24"
          alt=""
          style="border-radius: 5px;"
        />
        <span>Snap<b>2</b>Link</span>
      </a>
      <p class="tag">
        Screenshot → public link → clipboard. One keystroke.
      </p>
    </div>

    <div class="footer-col">
      <h4>Product</h4>
      <a href="#install">Download</a>
      <a href="https://github.com/amys94fr/Snap2Link/projects">Roadmap</a>
    </div>

    <div class="footer-col">
      <h4>Source</h4>
      <a href="https://github.com/amys94fr/Snap2Link">GitHub</a>
      <a href="https://github.com/amys94fr/Snap2Link/issues">Issues</a>
      <a
        href="https://github.com/amys94fr/Snap2Link/blob/main/CONTRIBUTING.md"
        >Contribute</a
      >
    </div>

    <div class="footer-col">
      <h4>Docs</h4>
      <a href="https://github.com/amys94fr/Snap2Link#readme">README</a>
      <a href="https://github.com/amys94fr/Snap2Link/releases">Release notes</a>
    </div>

    <div class="footer-col">
      <h4>Author</h4>
      <a href="https://github.com/amys94fr">GitHub profile</a>
    </div>
  </div>

  <div class="footer-bottom">
    <span>© {YEAR} Steven Abittan · MIT License</span>
    <div class="socials">
      <a href="https://github.com/amys94fr/Snap2Link" aria-label="GitHub">
