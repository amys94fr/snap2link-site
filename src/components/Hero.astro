---
import DemoFrame from "./DemoFrame.astro";
---

<section class="hero" id="top" data-screen-label="Hero">
  <span class="pill">
    <span class="dot"></span>
    v1.3.0 — out now
  </span>
  <h1>
    Paste screenshots into <span class="accent">Claude Code</span>, Cursor, or
    any terminal AI.
  </h1>
  <p class="lead">
    Hotkey → drag a region → public share link lands in your clipboard. One
    keystroke, on Windows, macOS, and Linux.
  </p>
  <div class="hero-ctas">
    <button class="btn primary lg">
      <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
        <path
          d="M3 5.5L11 4.5v7H3zM12 4.4L22 3v8.5H12zM3 12.5h8v7L3 18.5zM12 12.5h10V21l-10-1.4z"
        ></path>
      </svg>
      <span class="label" style="font-family: var(--font-sans); color: var(--color-slate-400); font-weight: 500; margin-right: 4px;">winget install</span>
      <code style="font-family: var(--font-mono); font-size: 13px;">snap2link</code>
    </button>
    <a class="btn outline lg" href="https://github.com/amys94fr/Snap2Link/releases/latest">
      <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
        <path
          d="M16.4 12.5c0-2.4 2-3.5 2.1-3.6-1.1-1.7-2.9-1.9-3.5-1.9-1.5-.2-2.9.9-3.7.9-.8 0-1.9-.9-3.2-.8-1.6 0-3.2.9-4 2.4-1.7 3-.4 7.5 1.3 10 .8 1.2 1.7 2.5 3 2.5 1.2 0 1.6-.8 3-.8s1.8.8 3 .8c1.3 0 2.1-1.2 2.9-2.4.9-1.4 1.3-2.7 1.3-2.8 0-.1-2.5-1-2.2-3.3zM14 5.2c.6-.8 1.1-1.9 1-3-.9 0-2 .6-2.6 1.4-.6.7-1.2 1.8-1 2.9 1 .1 2-.5 2.6-1.3z"
        ></path>
      </svg>
      Download .dmg
    </a>
    <a class="btn outline lg" href="#install">
      <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
        <path
          d="M12.5 2c-2.5 0-4.5 2-4.5 4.5 0 .8.2 1.5.5 2.2C7.4 9.6 6 11.5 6 13.5c0 1.4.6 2.6 1.6 3.5-.4.4-.6 1-.6 1.5 0 1 .5 1.8 1.4 2.4-.3.3-.5.7-.5 1.1 0 .9.7 1.5 2 1.5h4.2c1.3 0 2-.6 2-1.5 0-.4-.2-.8-.5-1.1.9-.6 1.4-1.4 1.4-2.4 0-.5-.2-1.1-.6-1.5 1-.9 1.6-2.1 1.6-3.5 0-2-1.4-3.9-2.5-4.8.3-.7.5-1.4.5-2.2C17 4 15 2 12.5 2z"
        ></path>
      </svg>
      curl | bash
    </a>
  </div>
  <DemoFrame />
</section>
