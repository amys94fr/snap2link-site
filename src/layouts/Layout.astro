---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Snap2Link · paste screenshots into Claude Code, Cursor, or any terminal AI",
  description = "Hotkey → drag a region → public share link lands in your clipboard. One keystroke, on Windows, macOS, and Linux. Free, open source, MIT licensed.",
} = Astro.props;

const SITE_URL = Astro.site ?? new URL("https://snap2link.app");
// `Astro.url.href` already includes the trailing slash for the index — keep it
// stable so the same canonical is emitted for / and /index.html requests.
const canonical = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImage = new URL("/og.png", SITE_URL).toString();

// Schema.org SoftwareApplication block — Google uses this to surface the
// app in rich results (download button, OS chips, ratings) and to crawl
// the GitHub release artefacts as the canonical install source.
const softwareLD = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Snap2Link",
  alternateName: "Snap2Link · Screenshot to Drive link",
  description:
    "Hotkey-driven screenshot tool that uploads to your Google Drive and copies a public share link to your clipboard. Built for AI workflows: Claude Code, Cursor, ChatGPT, Aider.",
  applicationCategory: "ProductivityApplication",
  operatingSystem: "Windows 10, Windows 11, macOS 12, Linux",
  softwareVersion: "1.3.0",
  url: SITE_URL.toString(),
  downloadUrl: "https://github.com/amys94fr/Snap2Link/releases/latest",
  installUrl: "https://github.com/amys94fr/Snap2Link/releases/latest",
  license: "https://opensource.org/license/mit",
  author: {
    "@type": "Person",
    name: "Steven Abittan",
    url: "https://github.com/amys94fr",
  },
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  featureList: [
    "Drag-to-capture screen region overlay",
    "Direct upload to your own Google Drive (drive.file scope)",
    "Public share link copied to clipboard",
    "Built-in annotator (pen, rectangle, circle, arrow, text, blur)",
    "Global rebindable hotkey",
    "Auto-cleanup of old screenshots",
    "Built-in auto-updater",
    "Cross-platform: Windows, macOS, Linux",
  ],
  keywords:
    "screenshot, screen capture, google drive, claude code, cursor, ai tools, productivity, tauri, open source",
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/assets/logo-app-icon.png" />
    <link rel="apple-touch-icon" href="/assets/logo-app-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Snap2Link" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0F172A" />
    <meta name="generator" content={Astro.generator} />

    <!-- Speed up the GitHub round-trips we link to repeatedly -->
    <link rel="preconnect" href="https://github.com" crossorigin />
    <link rel="dns-prefetch" href="https://github.com" />

    <!-- Preload Geist 700 (hero LCP) -->
    <link
      rel="preload"
      href="/_astro/files/geist-sans-latin-700-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Structured data for app rich results -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(softwareLD)}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
